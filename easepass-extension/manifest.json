{
  "manifest_version": 3,
  "name": "Accessibility Surfer",
  "version": "0.5.0",
  "description": "Universal dwell clicking on every site, with smart YouTube targeting on top. Plus text-accessibility controls.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "reading-mode.js", "reading-mode-trigger.js"],
      "css": ["content.css", "reading-mode.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Accessibility Surfer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts.css", "fonts/*", "icons/icon-128.png", "assistsurfer.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
